# Server Port
PORT=5000

# === Environment ===
NODE_ENV=development

# === JWT Configuration ===
# IMPORTANT: Use strong random secrets (at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: Do NOT use placeholder values like 'your-jwt-secret-here' in production!
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
CUSTOMER_ACCESS_TOKEN_TTL=12h

# === Cloudinary Configuration ===
# Get these from your Cloudinary Dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# === Database Configuration ===
# MySQL Database URL
DATABASE_URL=mysql://user:password@localhost:3306/database_name

# === CORS Configuration ===
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# === Cache Configuration ===
CACHE_WARMUP=true
CACHE_WARMUP_INTERVAL_MS=60000

# === Rate Limiting ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# === Email Configuration (Optional) ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@mymenueg.com

# === Payment Configuration (Optional) ===
# PAYMOB_API_KEY=your-paymob-key
# PAYMOB_INTEGRATION_ID=123
# PAYMOB_IFRAME_ID=123
# PAYMOB_HMAC_SECRET=your-hmac-secret
# PAYMOB_WALLET_INTEGRATION_ID=456
# FAWRY_MERCHANT_CODE=your-fawry-merchant-code
# FAWRY_SECURITY_KEY=your-fawry-security-key

# === Redis Configuration (Optional) ===
# REDIS_URL=redis://localhost:6379
